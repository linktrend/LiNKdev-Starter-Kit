{
  "name": "linkdev-starter-kit",
  "private": true,
  "packageManager": "pnpm@10.15.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --filter ./apps/web dev",
    "dev:web": "pnpm --filter ./apps/web dev",
    "dev:mobile": "pnpm --filter ./apps/mobile dev",
    "build": "pnpm --filter ./apps/web build",
    "lint": "pnpm --filter ./apps/web lint",
    "test": "pnpm --filter ./apps/web test",
    "typecheck": "pnpm --filter ./apps/web typecheck",
    "verify:web": "pnpm --filter ./apps/web verify",
    "verify:mobile": "pnpm --filter ./apps/mobile verify",
    "verify:all": "pnpm verify:web && pnpm verify:mobile",
    "test:web": "pnpm --filter ./apps/web test",
    "e2e:web": "pnpm --filter ./apps/web e2e",
    "test:mobile": "pnpm --filter ./apps/mobile test",
    "scaffold:app": "bash ./scripts/create-app-repo.sh",
    "release:gate": "bash ./scripts/release-readiness.sh",
    "release:alpha": "pnpm build && echo 'Release tag creation TBD'"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@jpisnice/shadcn-ui-mcp-server": "^1.1.4",
